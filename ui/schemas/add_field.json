{
  "type": "card",
  "titleKey": "addfield.title",
  "subtitleKey": "addfield.subtitle",
  "theme": "primary",
  "components": [
    {
      "type": "form",
      "fields": [
        {
          "type": "text",
          "name": "field_name",
          "labelKey": "onboarding.fields.fieldname.label",
          "placeholderKey": "onboarding.fields.fieldname.placeholder",
          "value": ""
        },
        {
          "type": "number",
          "name": "acres",
          "labelKey": "onboarding.fields.acres.label",
          "value": 5.0
        },
        {
          "type": "select",
          "name": "soil_type",
          "labelKey": "onboarding.fields.soil.label",
          "options": [
            {"value": "Black Clay (Cotton Soil)", "label": "Black Clay (Cotton Soil)"},
            {"value": "Red Sandy Loam", "label": "Red Sandy Loam"},
            {"value": "Alluvial", "label": "Alluvial"}
          ]
        },
        {
          "type": "select",
          "name": "primary_crop",
          "labelKey": "onboarding.fields.crop.label",
          "options": [
            {"value": "Corn", "label": "Maize / Corn"},
            {"value": "Wheat", "label": "Wheat"},
            {"value": "Soybeans", "label": "Soybeans"},
            {"value": "Rice", "label": "Rice"}
          ]
        },
        {
          "type": "select",
          "name": "has_drip",
          "labelKey": "onboarding.fields.irrigation.label",
          "options": [
            {"value": "yes", "labelKey": "onboarding.fields.irrigation.drip"},
            {"value": "no", "labelKey": "onboarding.fields.irrigation.sprinkler"}
          ]
        }
      ]
    },
    {
      "type": "buttons",
      "items": [
        {
          "labelKey": "addfield.action.save",
          "commandId": "SAVE_ADDITIONAL_FIELD",
          "variant": "primary"
        },
        {
          "labelKey": "addfield.action.cancel",
          "commandId": "CANCEL_ADD_FIELD",
          "variant": "ghost"
        }
      ]
    }
  ]
}