{
  "type": "card",
  "titleKey": "profile.title",
  "theme": "info",
  "components": [
    {
      "type": "text",
      "valueKey": "profile.desc"
    },
    {
      "type": "form",
      "fields": [
        {
          "type": "input",
          "name": "farmer_name",
          "labelKey": "profile.name.label",
          "placeholder": "e.g. Ramu Nayak"
        },
        {
          "type": "input",
          "name": "region",
          "labelKey": "profile.region.label",
          "placeholder": "e.g. Nagpur, Maharashtra"
        },
        {
          "type": "input",
          "name": "acres",
          "labelKey": "profile.acres.label",
          "placeholder": "e.g. 5"
        },
        {
          "type": "select",
          "name": "soil_type",
          "labelKey": "profile.soil.label",
          "options": [
            {"value": "Black Clay (Cotton Soil)", "label": "Black Clay (Cotton Soil)"},
            {"value": "Red Sandy Loam", "label": "Red Sandy Loam"},
            {"value": "Alluvial", "label": "Alluvial"},
            {"value": "Clay Loam", "label": "Clay Loam"}
          ]
        },
        {
          "type": "select",
          "name": "primary_crop",
          "labelKey": "profile.crop.label",
          "options": [
            {"value": "Corn", "label": "Maize / Corn"},
            {"value": "Wheat", "label": "Wheat"},
            {"value": "Soybeans", "label": "Soybeans"},
            {"value": "Rice", "label": "Rice"},
            {"value": "Cotton", "label": "Cotton"},
            {"value": "Sugarcane", "label": "Sugarcane"}
          ]
        },
        {
          "type": "select",
          "name": "has_drip",
          "labelKey": "profile.drip.label",
          "options": [
            {"value": "yes", "label": "Drip Irrigation"},
            {"value": "no", "label": "Sprinkler/Flood"}
          ]
        },
        {
          "type": "select",
          "name": "preferred_language",
          "labelKey": "profile.language.label",
          "options": [
            {"value": "English", "label": "English"},
            {"value": "Hindi", "label": "Hindi"},
            {"value": "Marathi", "label": "Marathi"},
            {"value": "Telugu", "label": "Telugu"},
            {"value": "Swahili", "label": "Swahili"},
            {"value": "Zulu", "label": "Zulu"}
          ]
        }
      ]
    },
    {
      "type": "button",
      "label": "Save Profile",
      "action": "save_farmer_profile"
    }
  ]
}
