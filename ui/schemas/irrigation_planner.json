{
  "type": "card",
  "titleKey": "irrigation.title",
  "theme": "info",
  "components": [
    {
      "type": "text",
      "valueKey": "irrigation.subtitle"
    },
    {
      "type": "grid",
      "columns": 2,
      "items": [
        {
          "type": "metric",
          "labelKey": "irrigation.water_need",
          "value": "15,000 Gallons",
          "status": "normal"
        },
        {
          "type": "metric",
          "labelKey": "irrigation.schedule",
          "value": "Every 3 Days",
          "status": "normal"
        }
      ]
    },
    {
      "type": "form",
      "fields": [
        {
          "type": "select",
          "name": "crop",
          "labelKey": "irrigation.select_crop",
          "options": ["Corn", "Wheat", "Soybeans", "Rice"]
        },
        {
          "type": "input",
          "name": "acres",
          "labelKey": "irrigation.field_size",
          "placeholderKey": "irrigation.field_size_placeholder"
        }
      ]
    },
    {
      "type": "button",
      "labelKey": "irrigation.calculate",
      "action": "calculate_irrigation"
    }
  ]
}