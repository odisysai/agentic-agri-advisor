# Terraform Variables — Example Template
#
# Copy this file to env.tfvars and fill in your real values:
#   cp vars/env.tfvars.example vars/env.tfvars
#
# env.tfvars is gitignored — your real values are never committed.

# Project name used for resource naming
project_name = "agentic-agri-advisor"

# Your Google Cloud project id (REPLACE THIS)
project_id = "your-gcp-project-id"

# The Google Cloud region for deployment
region = "us-east1"

# Gemini API key (set via TF_VAR_gemini_api_key env var, not here)
# gemini_api_key = "set-via-env-var-TF_VAR_gemini_api_key"

# Gemini model for the Ask Expert endpoint.
# Override here or set TF_VAR_expert_model_name in GitHub Actions.
# expert_model_name    = "gemini-2.5-flash"
# expert_model_fallback = "gemini-3.1-flash-lite"