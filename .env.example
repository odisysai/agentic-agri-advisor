# Google AI Studio API Key (for local development)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Platform (GCP) Configuration
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_LOCATION=us-east1
GOOGLE_GENAI_USE_VERTEXAI=False

# MCP Server Configuration URLs (if running SSE)
OKF_MCP_URL=http://localhost:8001/mcp/sse
RAG_MCP_URL=http://localhost:8002/mcp/sse
WEATHER_MCP_URL=http://localhost:8003/mcp/sse
MARKET_MCP_URL=http://localhost:8004/mcp/sse
IMAGE_MCP_URL=http://localhost:8005/mcp/sse
TTS_MCP_URL=http://localhost:8006/mcp/sse
STT_MCP_URL=http://localhost:8007/mcp/sse

# Optional browser model hosting. Leave unset for local /models/... files.
# If MODEL_ASSETS_* values are unset but GOOGLE_CLOUD_PROJECT is set, the app
# derives: <GOOGLE_CLOUD_PROJECT>-agentic-agri-advisor-assets.
MODEL_ASSETS_BUCKET_NAME=your-assets-bucket
MODEL_ASSETS_BASE_URL=https://storage.googleapis.com/your-assets-bucket/models
KRISHI_LOCAL_MODEL_NAME=Gemma-4-E2B
KRISHI_LOCAL_MODEL_URL=https://storage.googleapis.com/your-assets-bucket/models/gemma-4-E2B-it-web.litertlm
KRISHI_LITERT_LM_CORE_URL=https://cdn.jsdelivr.net/npm/@litert-lm/core/+esm
KRISHI_MODEL_LOAD_TIMEOUT_MS=30000
KRISHI_MODEL_INIT_TIMEOUT_MS=45000
KRISHI_MODEL_GENERATION_TIMEOUT_MS=20000
KRISHI_MODEL_ANSWER_TIMEOUT_MS=25000
KRISHI_MODEL_FOREGROUND_WAIT_MS=8000
KRISHI_CROP_CLASSIFIER_MODEL_URL=https://storage.googleapis.com/your-assets-bucket/models/crop_disease_classifier.tflite

# Local Google sign-in testing
# Also add http://localhost:8000 to the OAuth client's Authorized JavaScript origins.
GOOGLE_OIDC_ALLOW_LOCALHOST=1
